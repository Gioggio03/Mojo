# Utility functions of the MoStream library

fn print_green_color(text: String):
    print("\x1b[32m" + text + "\x1b[0m")

fn print_cyan_color(text: String):
    print("\x1b[36m" + text + "\x1b[0m")

fn print_red_color(text: String):
    print("\x1b[31m" + text + "\x1b[0m")

fn print_yellow_color(text: String):
    print("\x1b[33m" + text + "\x1b[0m")
